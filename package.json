{
	"name": "@iqai/mcp-limitless",
	"version": "0.0.5",
	"description": "Comprehensive MCP server for Limitless prediction markets - 27 tools for authentication, market data, portfolio management, and trading",
	"main": "dist/index.js",
	"type": "module",
	"bin": {
		"mcp-limitless": "dist/index.js"
	},
	"files": ["dist"],
	"scripts": {
		"build": "tsc && shx chmod +x dist/index.js",
		"prepare": "husky",
		"watch": "tsc --watch",
		"start": "node dist/index.js",
		"publish-packages": "pnpm run build && changeset publish",
		"format": "biome format . --write",
		"format:check": "biome ci .",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:unit": "vitest run tests/unit",
		"test:integration": "vitest run tests/integration",
		"test:coverage": "vitest run --coverage",
		"lint": "biome check .",
		"ci:check": "pnpm run format:check && pnpm test:unit && pnpm run build"
	},
	"author": "",
	"repository": {
		"type": "git",
		"url": "https://github.com/IQAIcom/mcp-limitless.git"
	},
	"license": "ISC",
	"homepage": "https://github.com/IQAIcom/mcp-limitless",
	"bugs": {
		"url": "https://github.com/IQAIcom/mcp-limitless/issues"
	},
	"publishConfig": {
		"access": "public"
	},
	"keywords": ["mcp", "limitless", "prediction-markets", "trading"],
	"dependencies": {
		"dedent": "^1.6.0",
		"fastmcp": "^3.30.1",
		"fetch-cookie": "^3.1.0",
		"tough-cookie": "^6.0.0",
		"ts-node": "^10.9.2",
		"winston": "^3.18.3",
		"zod": "^3.25.7"
	},
	"devDependencies": {
		"@biomejs/biome": "*",
		"@changesets/cli": "^2.29.4",
		"@types/node": "^24.0.3",
		"@vitest/coverage-v8": "^3.2.4",
		"ethers": "^6.15.0",
		"husky": "^9.0.0",
		"lint-staged": "^15.0.0",
		"msw": "^2.7.0",
		"shx": "^0.4.0",
		"typescript": "^5.8.3",
		"vitest": "^3.2.4",
		"zod-to-json-schema": "^3.25.1"
	},
	"lint-staged": {
		"*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc}": [
			"biome check --write --organize-imports-enabled=false --no-errors-on-unmatched"
		]
	}
}
